# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Claude model used for CV generation
CLAUDE_MODEL=claude-sonnet-4-6
# Reasoning effort (extended thinking): none / low / medium / high
# Cost on sonnet (single pass): none ~111 CVs/$10, low ~74, medium ~32, high ~24.
CLAUDE_EFFORT=none
# Model for the LinkedIn Job Summary API (browser extension). Separate from
# CLAUDE_MODEL above; Haiku is fast and cheap for short summaries.
SUMMARY_MODEL=claude-haiku-4-5
# Second expert QA pass: off. The verify/fix checklist is folded into the single
# generation prompt (STEP 12), so one call produces the final CV. on / off
CV_REVIEW=off

# Master switch for CV generation. on / off (default on).
#   on  = new jobs get a full CV + their info written to the sheet.
#   off = new jobs are still imported and their page info (city, company, title,
#         work type...) is saved to the sheet, but NO CV is produced. Such rows get
#         the marker "Yok" in the CV No column (N) so they are handled once and are
#         NOT retro-generated when you turn the switch back on. Clear "Yok" from N by
#         hand if you later decide you want a CV for that specific row.
CV_GENERATION=on

# Google Sheets spreadsheet ID (the long id in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit )
SPREADSHEET_ID=

# Tab/worksheet name that holds the job rows (default Google TR is "Sayfa1")
SHEET_NAME=Sayfa1

# Polling interval in seconds
POLL_INTERVAL=60

# Where generated CVs are written (cv_<no>.md). ~ is expanded.
OUTPUT_DIR=~/Desktop/İş Arama/Job Applications/2026/CVs

# Where the Turkish ATS analysis files are written (cv_<no>_analysis.md).
ANALYSIS_DIR=~/Desktop/İş Arama/Job Applications/2026/CV_Analysis

# Where scraped job descriptions are saved for traceability.
JOB_DESCRIPTION_DIR=~/Desktop/İş Arama/Job Applications/2026/Job Description

# Drive folder (in YOUR account) where the Google Doc CVs are created.
RESUMES_FOLDER_NAME=Resumes Based on Jobs
# Optional: set the folder's ID directly (from its Drive URL) to skip name lookup.
RESUMES_FOLDER_ID=

# --- Huntr integration (OPTIONAL) ---
# Leave HUNTR_BOARD_URL empty to keep Huntr OFF (app behaves as before).
# Set it to your Huntr board URL to auto-import saved jobs into the sheet.
HUNTR_BOARD_URL=
# How often (seconds) to check the Huntr board.
HUNTR_POLL_INTERVAL=30
