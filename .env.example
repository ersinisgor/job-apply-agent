# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Claude model used for CV generation
CLAUDE_MODEL=claude-sonnet-4-6

# Google Sheets spreadsheet ID (the long id in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit )
SPREADSHEET_ID=

# Tab/worksheet name that holds the job rows (default Google TR is "Sayfa1")
SHEET_NAME=Sayfa1

# Polling interval in seconds
POLL_INTERVAL=60

# Where generated CVs are written (cv_<no>.md). ~ is expanded.
OUTPUT_DIR=~/Desktop/İş Arama/Job Applications/2026/CVs

# Where the Turkish ATS analysis files are written (cv_<no>_analysis.md).
ANALYSIS_DIR=~/Desktop/İş Arama/Job Applications/2026/CV_Analysis

# Where scraped job descriptions are saved for traceability.
JOB_DESCRIPTION_DIR=~/Desktop/İş Arama/Job Applications/2026/Job Description

# Drive folder (in YOUR account) where the Google Doc CVs are created.
RESUMES_FOLDER_NAME=Resumes Based on Jobs
# Optional: set the folder's ID directly (from its Drive URL) to skip name lookup.
RESUMES_FOLDER_ID=
